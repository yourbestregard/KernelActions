{
  "kernelSource": {
    "device": "ginkgo",
    "vendor": "xiaomi",
    "name": "bimasakti-sixty",
    "defconfig": "defconfig",
    "extraConfig": "",
    "repo": "https://github.com/yourbestregard/android_kernel_xiaomi_ginkgo",
    "branch": "LA.UM.9.1.r1-08100-SMxxx0.0"
  },
  "use_dtb": false,
  "kp": {
    "use": false,
    "kpimg_link": ""
  },
  "kernelsu": {
    "enable": true,
    "setupLink": "https://raw.githubusercontent.com/KernelSU-Next/KernelSU-Next/next/kernel/setup.sh",
    "setupArg": "-s legacy",
    "setupName": "KernelSU-Next",
    "needPatch": true,
    "susfsLink": "https://raw.githubusercontent.com/wodanesdag/susfs4ksu/refs/heads/next-4.14/kernel_patches/KernelSU/10_enable_susfs_for_ksu.patch"
  },
  "toolchains": [
    {
      "repo": "https://gitlab.com/DR-KernelArchive/clang/r547379",
      "branch": "master",
      "name": "clang-AOSP",
      "binPath": ["/bin"]
    }
  ],
  "ccache": true,
  "params": {
    "ARCH": "arm64",
    "CC": "clang-AOSP/bin/clang",
    "externalCommand": {
      "KBUILD_BUILD_HOST": "t.me/azmunaashome.",
      "KBUILD_BUILD_USER": "yourbestregard",
      "CROSS_COMPILE": "clang-AOSP/bin/aarch64-linux-gnu-",
      "CROSS_COMPILE_ARM32": "clang-AOSP/bin/arm-linux-gnueabi-",
      "LD": "clang-AOSP/bin/ld.lld",
      "LLVM": "1",
      "LLVM_IAS": "1",
      "AR": "clang-AOSP/bin/llvm-ar",
      "NM": "clang-AOSP/bin/llvm-nm",
      "OBJCOPY": "clang-AOSP/bin/llvm-objcopy",
      "OBJDUMP": "clang-AOSP/bin/llvm-objdump",
      "READELF": "clang-AOSP/bin/llvm-readelf",
      "OBJSIZE": "clang-AOSP/bin/llvm-size",
      "STRIP": "clang-AOSP/bin/llvm-strip",
      "LDGOLD": "clang-AOSP/bin/aarch64-linux-gnu-ld.gold",
      "LLVM_AR": "clang-AOSP/bin/llvm-ar",
      "LLVM_DIS": "clang-AOSP/bin/llvm-dis"
    }
  },
  "image": {
    "use": true,
    "imageUrl": "https://github.com/yourbestregard/KernelActions/releases/download/cloud/boot.img",
    "imageName": "boot.img"
  },
  "AnyKernel3": {
    "use": true,
    "release": true,
    "repo": "https://github.com/FlopKernel-Series/AnyKernel3-trinket",
    "branch": "floppy-reborn"
  }
